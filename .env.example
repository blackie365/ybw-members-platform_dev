# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key
CLERK_WEBHOOK_SECRET=your_webhook_secret

# Ghost CMS
GHOST_URL=your_ghost_url
GHOST_CONTENT_API_KEY=your_content_api_key
GHOST_ADMIN_API_KEY=your_admin_api_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_publishable_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# Resend (Modern Email)
RESEND_API_KEY=your_resend_api_key

# Mailgun (Legacy)
MAILGUN_API_KEY=your_mailgun_key
MAILGUN_DOMAIN=your_domain

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
GA4_PROPERTY_ID_CURRENT=your-current-ga4-property-id
GA4_PROPERTY_ID_LEGACY=your-legacy-ga4-property-id
# Optional fallback if you only use a single GA4 property
GA4_PROPERTY_ID=your-default-ga4-property-id
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Meta Social Reporting
# Shared fallback user token. If present, the app can derive the Facebook page token
# from /me/accounts and also use it for Instagram business account reads.
META_ACCESS_TOKEN=your-meta-user-access-token-with-pages-and-instagram-scopes
# Optional explicit Facebook page token for page-level reads
META_FACEBOOK_ACCESS_TOKEN=your-facebook-page-access-token
# Optional explicit Instagram user token for Instagram account and insights reads
META_INSTAGRAM_ACCESS_TOKEN=your-instagram-user-access-token
META_FACEBOOK_PAGE_ID=your-facebook-page-id
# Optional if the Facebook page is already linked to Instagram
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id
META_GRAPH_API_VERSION=v25.0
