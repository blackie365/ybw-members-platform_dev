rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. Profile & Banner Images: Users can only upload/edit their own
    match /profile-images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /banner-images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Article Images: Any logged-in member can upload, everyone can read
    match /article-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 3. Company Logos: Managed by Admin
    match /company-logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 4. Magazine Imports: Admin-initiated uploads (auth checked server-side)
    match /magazine-import/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // Default: Allow read, deny write
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
